{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "allow-wapp-commands",
      "commands": {
        "allow": [
          "check_dependencies",
          "load_wapps",
          "save_wapps",
          "build_wapp",
          "launch_wapp",
          "open_workspace_folder"
        ]
      }
    }
  ]
}
