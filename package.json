    "vite": "vite",
    "lint": "tsc --noEmit",
    "prettier": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepare": "node scripts/prepare-base.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
