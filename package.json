{
  "name": "wapp-desktop",
  "version": "0.1.0",
  "description": "Turn any web app, dashboard, or URL into a native desktop app in seconds",
  "homepage": "https://github.com/jvondev/wapp",
  "repository": {
    "type": "git",
    "url": "https://github.com/jvondev/wapp.git"
  },
  "keywords": [
    "desktop",
    "app-builder",
    "tauri",
    "web-to-desktop",
    "native-app",
    "wrapper",
    "dashboard",
    "electron-alternative"
  ],
